// RANDOM file test using WRITE FILE (always binary)
TRAP
  DELETE "test_random_write.dat"
ENDTRAP

// Write records with RANDOM 20
OPEN FILE 1, "test_random_write.dat", RANDOM 20
FOR i:=1 TO 3 DO
  WRITE FILE 1,i: i*10, i*20
ENDFOR
CLOSE FILE 1

// Read back the same records with same record size
OPEN FILE 1, "test_random_write.dat", RANDOM 20
FOR i:=1 TO 3 DO
  READ FILE 1,i: x
  PRINT USING "###": x;
  IF x<>i*10 THEN
    PRINT " ERROR: Expected"; i*10; "got"; x
    STOP
  ENDIF
ENDFOR
CLOSE FILE 1

PRINT
PRINT "All ok"
