// draw_text.lst — test DRAW text and fontSize commands
// Expected output: (nothing to stdout; program must run without error)

DRAW background, 0, 0, 0

// Default fontSize (12) — draw a label
label$ := "Hello World"
DRAW text, 50, 30, label$

// Change fontSize and draw another label
DRAW fontSize, 24
DRAW stroke, 255, 255, 0
DRAW text, 50, 70, "Big text"

// Draw in a named group
DRAW fontSize, 10
DRAW stroke, 200, 200, 200
DRAW "HUD.text", 5, 5, "Score: 0"

PRINT "draw_text OK"
