// RANDOM file test with non-sequential record writes
OPEN FILE 1, "test_random_skip.dat", RANDOM 20
WRITE FILE 1,1: 100
WRITE FILE 1,3: 300
CLOSE FILE 1

OPEN FILE 1, "test_random_skip.dat", RANDOM 20
READ FILE 1,1: x
PRINT "Record 1:"; x
IF x<>100 THEN STOP

READ FILE 1,3: y
PRINT "Record 3:"; y
IF y<>300 THEN STOP

CLOSE FILE 1
PRINT "OK"
