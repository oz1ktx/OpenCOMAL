// The Pink Panther Theme - H. Mancini
// ABC header sent once; body lines played individually.
// The sound engine keeps L:/Q: state between PLAY calls, so no prefix needed.
// PLAY "STOP" resets parser state back to defaults.
PRINT "The Pink Panther - H. Mancini"
PLAY "L:1/8 Q:1/4=123"
FOR i := 1 TO 9
  READ line$
  PLAY line$
NEXT i
PRINT "done"
DATA "z4 z3/2^D/2 E/2z^E/2|F8-|F4- F/2z^D/2 =E/2z^E/2|F8-|F4- F/2z^E/2 =E/2z^D/2|=D8-|D4- D/2z^D/2 E/2z^E/2|F8-|"
