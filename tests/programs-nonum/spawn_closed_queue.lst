PRINT "SPAWN CLOSED queue basic"
SPAWN worker

OPEN QUEUE 1, "Q_SPAWN_IN", WRITE
PRINT QUEUE 1: "PING"
CLOSE QUEUE 1

OPEN QUEUE 2, "Q_SPAWN_OUT", READ
INPUT QUEUE 2: msg$
CLOSE QUEUE 2

IF msg$<>"PONG" THEN STOP
PRINT "All ok"

PROC worker CLOSED
  OPEN QUEUE 3, "Q_SPAWN_IN", READ
  INPUT QUEUE 3: req$
  CLOSE QUEUE 3
  helper(req$)
ENDPROC

PROC helper(text$) CLOSED
  OPEN QUEUE 4, "Q_SPAWN_OUT", WRITE
  IF text$="PING" THEN PRINT QUEUE 4: "PONG"
  CLOSE QUEUE 4
ENDPROC
