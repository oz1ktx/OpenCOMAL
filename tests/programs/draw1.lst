0010 // DRAW command - graphics engine test
0020 DRAW "background", 240, 240, 255
0030 DRAW "stroke", 0, 0, 0
0040 DRAW "fill", 0, 128, 255, 128
0050 DRAW "rect", 10, 20, 100, 50
0060 DRAW "circle", 200, 200, 80
0070 DRAW "line", 0, 0, 300, 300
0080 // Single-string form
0090 DRAW "noFill"
0100 DRAW "lineWidth 3"
0110 DRAW "ellipse 100 300 120 60"
0120 // Variables in DRAW
0130 x:=350
0140 y:=150
0150 r:=40
0160 DRAW "circle", x, y, r
0170 // Grouped sprites
0180 DRAW "Spaceship.fill", 128, 128, 128
0190 DRAW "Spaceship.rect", 400, 50, 80, 40
0200 PRINT "All ok"
0210 END
