// Mandelbrot set demo using DRAW pixel
// Renders a 640x480 view centered roughly on the classic set

maxIter := 80
xmin := -2.2
xmax := 1.0
ymin := -1.2
ymax := 1.2

// Black background for better contrast
DRAW background, 0, 0, 0

FOR py := 0 TO 479
  cy := ymin + (ymax - ymin) * py / 479

  FOR px := 0 TO 639
    cx := xmin + (xmax - xmin) * px / 639

    x := 0
    y := 0
    iter := 0

    // z = z^2 + c iteration
    WHILE iter < maxIter AND x*x + y*y <= 4
      xt := x*x - y*y + cx
      y := 2*x*y + cy
      x := xt
      iter :+ 1
    ENDWHILE

    IF iter = maxIter THEN
      // Inside set -> black
      DRAW pixel, px, py, 0, 0, 0
    ELSE
      // Outside set -> smooth-ish gradient bands
      r := (iter * 9) MOD 256
      g := (iter * 5) MOD 256
      b := (iter * 13) MOD 256
      DRAW pixel, px, py, r, g, b
    ENDIF

  NEXT px
NEXT py

PRINT "Mandelbrot complete"
END
