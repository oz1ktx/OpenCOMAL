	cd /home/peter/Workspace/OpenCOMAL/build && $(MAKE) $(MAKESILENT) -f comal-ide/CMakeFiles/comal-ide.dir/build.make comal-ide/CMakeFiles/comal-ide.dir/src/qt_io.cpp.s
