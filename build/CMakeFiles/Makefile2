comal-ide/CMakeFiles/comal-ide_autogen.dir/codegen: comal-ide/CMakeFiles/comal-ide_autogen_timestamp_deps.dir/all
	$(MAKE) $(MAKESILENT) -f comal-ide/CMakeFiles/comal-ide_autogen.dir/build.make comal-ide/CMakeFiles/comal-ide_autogen.dir/codegen
	@$(CMAKE_COMMAND) -E cmake_echo_color "--switch=$(COLOR)" --progress-dir=/home/peter/Workspace/OpenCOMAL/build/CMakeFiles --progress-num=20 "Finished codegen for target comal-ide_autogen"
.PHONY : comal-ide/CMakeFiles/comal-ide_autogen.dir/codegen

# clean rule for target.
comal-ide/CMakeFiles/comal-ide_autogen.dir/clean:
	$(MAKE) $(MAKESILENT) -f comal-ide/CMakeFiles/comal-ide_autogen.dir/build.make comal-ide/CMakeFiles/comal-ide_autogen.dir/clean
.PHONY : comal-ide/CMakeFiles/comal-ide_autogen.dir/clean

#=============================================================================
# Special targets to cleanup operation of make.

# Special rule to run CMake to check the build system integrity.
# No rule that depends on this can have commands that come from listfiles
# because they might be regenerated.
cmake_check_build_system:
	$(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles/Makefile.cmake 0
.PHONY : cmake_check_build_system

